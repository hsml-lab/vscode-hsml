// SYNTAX TEST "text.hsml" "Basic HSML syntax"

// This is a developer comment
// <--- comment.line.double-slash.hsml

//! This is an HTML comment
//  <--- string.comment.buffered.block.hsml

 doctype html
//^^^^^^ keyword.other.doctype.hsml
//       ^^^^ entity.name.type.hsml

 div Hello World
// ^ entity.name.tag.hsml

 h1 Title
//^ entity.name.tag.hsml

 my-component Hello
// ^ entity.name.tag.hsml

 div#myid
// ^ entity.name.tag.hsml
//  ^ meta.attribute-name.id.css.hsml
//   ^ entity.other.attribute-name.id.css.hsml

 div.container
// ^ entity.name.tag.hsml
//  ^ meta.attribute-name.class.css.hsml
//   ^ entity.other.attribute-name.class.css.hsml

 div.foo.bar
//      ^ meta.attribute-name.class.css.hsml
//       ^^^ entity.other.attribute-name.class.css.hsml

 div#id.class
//  ^ meta.attribute-name.id.css.hsml
//   ^^ entity.other.attribute-name.id.css.hsml
//     ^ meta.attribute-name.class.css.hsml
//      ^^^^^ entity.other.attribute-name.class.css.hsml
