// SYNTAX TEST "text.hsml" "Basic HSML syntax"

// This is a developer comment
// <--- comment.line.double-slash.hsml

//! This is an HTML comment
//  <--- string.comment.buffered.block.hsml

 doctype html
//^^^^^^ keyword.other.doctype.hsml
//       ^^^^ entity.name.type.hsml

 div Hello World
// ^ entity.name.tag.hsml

 h1 Title
//^ entity.name.tag.hsml

 my-component Hello
// ^ entity.name.tag.hsml

 PwaBadge.xl:hidden
//^^^^^^^ entity.name.tag.hsml

 NavUser(v-if="isHydrated")
//^^^^^^ entity.name.tag.hsml

 div#myid
// ^ entity.name.tag.hsml
//  ^ meta.attribute-name.id.css.hsml
//   ^ entity.other.attribute-name.id.css.hsml

 div.container
// ^ entity.name.tag.hsml
//  ^ meta.attribute-name.class.css.hsml
//   ^ entity.other.attribute-name.class.css.hsml

 div.foo.bar
//      ^ meta.attribute-name.class.css.hsml
//       ^^^ entity.other.attribute-name.class.css.hsml

 div#id.class
//  ^ meta.attribute-name.id.css.hsml
//   ^^ entity.other.attribute-name.id.css.hsml
//     ^ meta.attribute-name.class.css.hsml
//      ^^^^^ entity.other.attribute-name.class.css.hsml

 .container
// ^ entity.other.attribute-name.class.css.hsml

 #section
// ^ entity.other.attribute-name.id.css.hsml

 div.bg-[#1da1f2]
//  ^ meta.attribute-name.class.css.hsml
//   ^ entity.other.attribute-name.class.css.hsml

 div.md:p-8.text-center
//  ^ meta.attribute-name.class.css.hsml
//   ^ entity.other.attribute-name.class.css.hsml
//         ^ meta.attribute-name.class.css.hsml
//          ^ entity.other.attribute-name.class.css.hsml

 div(class="foo")
//  ^ punctuation.section.attributes.begin.hsml
//   ^^^^^ entity.other.attribute-name.hsml
//         ^^^^^ string.quoted.hsml
//              ^ punctuation.section.attributes.end.hsml

 div(v-if="show")
//   ^^^^ keyword.control.directive.hsml

 div(v-else)
//   ^^^^^^ keyword.control.directive.hsml

 img(:src="url")
//   ^^^^ entity.other.attribute-name.hsml

 button(@click="handler")
//      ^^^^^^ entity.other.attribute-name.hsml

 input(disabled)
//     ^^^^^^^^ entity.other.attribute-name.hsml
