{
  "name": "hsml",
  "displayName": "hsml",
  "version": "0.1.0",
  "description": "hsml support for Visual Studio Code",
  "categories": [
    "Programming Languages"
  ],
  "license": "MIT",
  "author": {
    "name": "Christopher Quadflieg",
    "email": "chrissi92@hotmail.de",
    "url": "https://github.com/Shinigami92"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hsml-lab/vscode-hsml.git"
  },
  "publisher": "Shinigami92",
  "type": "commonjs",
  "scripts": {
    "clean": "git clean -fdx --exclude .claude",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint",
    "preflight": "pnpm install && run-s format lint"
  },
  "devDependencies": {
    "@types/node": "24.12.0",
    "npm-run-all2": "8.0.4",
    "oxfmt": "0.42.0",
    "oxlint": "1.57.0"
  },
  "contributes": {
    "grammars": [
      {
        "language": "hsml",
        "scopeName": "text.hsml",
        "path": "./syntaxes/hsml.tmLanguage.json"
      }
    ],
    "languages": [
      {
        "id": "hsml",
        "aliases": [
          "HSML",
          "hsml"
        ],
        "extensions": [
          ".hsml"
        ],
        "configuration": "./language-configuration.json"
      }
    ]
  },
  "engines": {
    "vscode": "^1.98.0"
  },
  "packageManager": "pnpm@10.33.0"
}
